<!DOCTYPE html>
<html>
<head>
    <title>Produkty</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<div class="container mt-5">
    <h1 class="mb-4">Seznam produktů</h1>

    <a href="/create" class="btn btn-primary mb-3">+ Přidat produkt</a>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Název</th>
                <th>Cena</th>
                <th>Akce</th>
            </tr>
        </thead>
        <tbody>

        <% if (products && products.length > 0) { %>
            <% products.forEach(function(p) { %>
                <tr>
                    <td><%= p.name %></td>
                    <td><%= p.price %> Kč</td>
                    <td>
                        <a href="/edit/<%= p.id %>" class="btn btn-warning btn-sm">Edit</a>
                        <a href="/delete/<%= p.id %>" class="btn btn-danger btn-sm">Delete</a>
                    </td>
                </tr>
            <% }) %>
        <% } else { %>
            <tr>
                <td colspan="3" class="text-center">Žádné produkty</td>
            </tr>
        <% } %>

        </tbody>
    </table>
</div>

</body>
</html>